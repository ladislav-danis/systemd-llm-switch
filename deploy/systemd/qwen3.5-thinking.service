[Unit]
# Description of the service
Description=Llama-CPP Server (Qwen3.5-Thinking-35B-A3B-8GB)
# Service should start after network and nvidia services are available
After=network.target
After=network.target nvidia-persistenced.service

[Service]
# Working directory where the llama-server executable is located
WorkingDirectory={{LLAMA_BIN_DIR}}

# Main command to start the llama-server with various parameters
ExecStart={{LLAMA_SERVER_PATH}} \
--model {{MODELS_DIR}}/unsloth_Qwen3.5-35B-A3B-GGUF_Qwen3.5-35B-A3B-UD-Q4_K_XL.gguf \
--mmproj {{MODELS_DIR}}/unsloth_Qwen3.5-35B-A3B-GGUF_mmproj-BF16.gguf \
--threads 3 \
-np 1 \
--batch-size 2560 \
--ubatch-size 2560 \
--ctx-size 81920 \
--cache-type-k q8_0 \
--cache-type-v q8_0 \
--jinja \
--seed 32 \
--temp 0.6 --min-p 0.00 --top-p 0.95 --top-k 20 \
--flash-attn on \
-a qwen3.5-thinking \
--n-gpu-layers 49 \
--override-tensor ".*blk\.([0-9]|[1-3][0-9]|4[0-8])\.ffn_.*_exps.*=CPU" \
--host 0.0.0.0 \
--port 3004

# Restart the service if it crashes or stops
Restart=always
# Wait 5 seconds before restarting
RestartSec=5

[Install]
# Service should be started when the system reaches multi-user target
WantedBy=multi-user.target
